# Supabase Integration Credentials
# Copy this file to .env.local and replace with your actual keys from Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (for server-side API routes)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMS Provider (choose one)
# For Philippines: Semaphore is cheapest (~₱0.50/sms). Get API key at https://semaphore.co
# For global: Twilio. Get credentials at https://twilio.com
# For testing without credits: use SMS_PROVIDER=mock

# Option 1: Semaphore (RECOMMENDED for Philippines)
SEMAPHORE_API_KEY=your_semaphore_api_key
SEMAPHORE_SENDER_NAME=EMCARD
SMS_PROVIDER=semaphore

# Option 2: Twilio (Global)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number
# SMS_PROVIDER=twilio

# Option 3: Mock (testing, no real SMS sent)
# SMS_PROVIDER=mock
